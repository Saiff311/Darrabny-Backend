# 🚀 Darrabny Backend - Environment Variables Configuration Example
# Copy this file to '.env' and fill in your actual credentials.

# --- SERVER CONFIGURATION ---
PORT=3000
NODE_ENV=development

# --- DATABASE CONFIGURATION ---
# MongoDB Atlas Connection String or Local URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/darrabny?retryWrites=true&w=majority

# --- SECURITY & AUTHENTICATION ---
# Super secret key for signing JWT tokens
JWT_SECRET=your_ultra_secure_jwt_secret_phrase_here
JWT_EXPIRES_IN=7d

# --- CLOUDINARY STORAGE CONFIGURATION (For Resumes, Reports, & Images) ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- EMAIL SERVICE CONFIGURATION (For OTP & Notifications) ---
# SMTP configurations (e.g., Gmail)
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here

# --- MACHINE LEARNING SERVICE ---
# URL for Python/FastAPI ML microservice if separated
ML_SERVICE_URL=http://localhost:8000
